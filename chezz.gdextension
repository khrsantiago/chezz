[configuration]
entry_symbol = "chezz_library_init"
compatibility_minimum = 4.1

[libraries]
linux.debug.x86_64 = "res://bin/libchezz.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://bin/libchezz.linux.template_release.x86_64.so"
windows.debug.x86_64 = "res://bin/libchezz.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://bin/libchezz.windows.template_release.x86_64.dll"